# =========================
# Creator AI Platform
# =========================
APP_NAME=Creator AI Platform
APP_ENV=development
JWT_SECRET_KEY=change-me-super-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./creator_ai.db
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BASE_URL=http://localhost:8000
PUBLIC_STORAGE_URL=http://localhost:8000/storage

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TRANSCRIBE_MODEL=whisper-1

# YouTube Data API
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=EG

# Optional trend providers
APIFY_TOKEN=
APIFY_TIKTOK_ACTOR_ID=
APIFY_INSTAGRAM_ACTOR_ID=

# Optional fal.ai for avatar / video animation
FAL_KEY=
FAL_AVATAR_MODEL=fal-ai/ai-avatar/single-text
FAL_VIDEO_MODEL=fal-ai/minimax-video/image-to-video

# Media
FFMPEG_BINARY=ffmpeg
DEFAULT_BG_MUSIC_URL=
